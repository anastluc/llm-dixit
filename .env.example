# ── Primary (required) ──────────────────────────────────────────────────────
# Get at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: shown in OpenRouter dashboard analytics
OPENROUTER_SITE_URL=https://github.com/LLM_dixit
OPENROUTER_APP_NAME=LLM Dixit Arena

# ── Direct provider fallbacks (only needed for models not on OpenRouter) ─────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
GROQ_API_KEY=gsk_...
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
XAI_GROK_API_KEY=xai-...

# ── App settings ─────────────────────────────────────────────────────────────
GAME_LOGS_DIR=game_logs
DATA_DIR=data

# ── Firebase Firestore + Storage (optional) ──────────────────────────────────
# Option A: path to your downloaded service-account JSON file
# FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json
# Option B: paste the service-account JSON inline (useful for cloud deploys)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# Firestore collection name (default: dixit_games)
# FIREBASE_COLLECTION=dixit_games
# Firebase Storage bucket — found in Firebase console → Storage → gs://your-project.appspot.com
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
